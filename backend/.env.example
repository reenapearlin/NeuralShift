PROJECT_NAME=NeuralShift Legal AI API
API_V1_PREFIX=/api/v1

# Prefer DATABASE_URL for clarity
DATABASE_URL=postgresql+psycopg2://postgres:YOUR_DB_PASSWORD@localhost:5434/neuralshift

# Optional split DB config (used if DATABASE_URL is not set)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_DB_PASSWORD
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_DB=neuralshift

SECRET_KEY=GENERATE_A_STRONG_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Local storage root for case PDFs
CASEFILES_ROOT_DIR=D:/NeuralShift/backend/storage/casefiles
