# -----------------------------
# Backend application settings
# -----------------------------
PROJECT_NAME=NeuralShift Legal AI API
API_V1_PREFIX=/api/v1

# -----------------------------
# PostgreSQL (docker-compose defaults)
# -----------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ShuValt123
POSTGRES_DB=neuralshift
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
# If set, DATABASE_URL overrides the 5 vars above.
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5434/neuralshift

# -----------------------------
# Auth / JWT
# -----------------------------
SECRET_KEY=change_this_secret_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# -----------------------------
# File storage
# -----------------------------
CASEFILES_ROOT_DIR=backend/storage/casefiles

# -----------------------------
# RAG / Ollama
# -----------------------------
RAG_OLLAMA_BASE_URL=http://127.0.0.1:11434
RAG_LLM_MODEL=llama3
RAG_EMBEDDING_MODEL=nomic-embed-text
RAG_FAISS_INDEX_DIR=backend/storage/faiss
RAG_FAISS_INDEX_NAME=section138_cases
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5

# -----------------------------
# Dynamic Precedent Scraper
# -----------------------------
PRECEDENT_SCRAPER_BASE_URL=https://indiankanoon.org/search/
PRECEDENT_SCRAPER_USER_AGENT=NeuralShiftLegalBot/1.0 (+https://neuralshift.local)
PRECEDENT_SCRAPER_MAX_RESULTS=10
PRECEDENT_SCRAPER_TIMEOUT=20
PRECEDENT_SCRAPER_DELAY_SECONDS=1.0
PRECEDENT_SCRAPER_MAX_TEXT_CHARS=20000
PRECEDENT_SEARCH_TOP_N=5
PRECEDENT_SNIPPET_CHARS=300

# -----------------------------
# Frontend
# -----------------------------
VITE_API_BASE_URL=http://localhost:8000
